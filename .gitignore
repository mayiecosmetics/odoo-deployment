# Environment variables (contains secrets)
.env

# Generated runtime config (rendered from template at startup)
config/odoo.conf

# Docker volumes (data is local, not versioned)
volumes/

# Backups (too large for git)
backups/

# Logs
*.log

# Python cache
__pycache__/
*.pyc

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo

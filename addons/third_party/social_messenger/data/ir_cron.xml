<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Optional: Cron to periodically check connection status -->
        <record id="ir_cron_social_health_check" model="ir.cron">
            <field name="name">Social Messenger: Health Check</field>
            <field name="model_id" ref="model_social_account"/>
            <field name="state">code</field>
            <field name="code">
accounts = env['social.account'].search([('state', '=', 'connected')])
for account in accounts:
    try:
        account.action_test_connection()
    except Exception:
        pass
            </field>
            <field name="interval_number">6</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="active">False</field>
        </record>
    </data>
</odoo>

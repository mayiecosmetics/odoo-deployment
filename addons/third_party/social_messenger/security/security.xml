<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="module_category_social_messenger" model="ir.module.category">
            <field name="name">Social Messenger</field>
            <field name="sequence">50</field>
        </record>

        <record id="group_social_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_social_messenger"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_social_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_social_messenger"/>
            <field name="implied_ids" eval="[(4, ref('group_social_user'))]"/>
        </record>
    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Top-level App Menu -->
    <menuitem id="menu_social_messenger_root"
              name="Social Messenger"
              web_icon="social_messenger,static/description/icon.png"
              sequence="90"/>

    <!-- Conversations -->
    <menuitem id="menu_social_conversations"
              name="Conversations"
              parent="menu_social_messenger_root"
              action="action_social_conversation"
              sequence="10"/>

    <!-- All Messages -->
    <menuitem id="menu_social_messages"
              name="All Messages"
              parent="menu_social_messenger_root"
              action="action_social_message"
              sequence="20"/>

    <!-- Configuration -->
    <menuitem id="menu_social_configuration"
              name="Configuration"
              parent="menu_social_messenger_root"
              sequence="90"/>

    <menuitem id="menu_social_accounts"
              name="Social Accounts"
              parent="menu_social_configuration"
              action="action_social_account"
              sequence="10"/>

</odoo>

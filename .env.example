# =============================================================================
# Odoo Deployment — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# NEVER commit .env to git.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_DB=mayie_erp
POSTGRES_USER=odoo
POSTGRES_PASSWORD=change-me-strong-password

# ---------------------------------------------------------------------------
# Odoo
# ---------------------------------------------------------------------------
ODOO_ADMIN_PASSWORD=change-me-master-password
ODOO_PORT=8069
ODOO_CHAT_PORT=8072

# ---------------------------------------------------------------------------
# Odoo tuning (leave commented for local dev; uncomment/set on Hetzner)
# ---------------------------------------------------------------------------
# ODOO_PROXY_MODE=True          # Set True in production (behind nginx)
# ODOO_LOG_LEVEL=warn           # info | warn | error
# ODOO_WORKERS=4                # 0 = single-threaded dev; 4+ for production
# ODOO_CRON_THREADS=2
# ODOO_LIST_DB=False            # Set False in production
# ODOO_LIMIT_MEMORY_HARD=2684354560
# ODOO_LIMIT_MEMORY_SOFT=2147483648
# ODOO_LIMIT_TIME_CPU=60
# ODOO_LIMIT_TIME_REAL=120
# ODOO_LIMIT_REQUEST=8192

# ---------------------------------------------------------------------------
# MinIO — S3-compatible object storage
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---------------------------------------------------------------------------
# S3 / MinIO — Odoo attachment storage
# ---------------------------------------------------------------------------
S3_BUCKET=odoo-attachments
S3_REGION=us-east-1
# Internal Docker network endpoint — do not change unless MinIO runs elsewhere
S3_ENDPOINT_URL=http://minio:9000

# ---------------------------------------------------------------------------
# Odoo Enterprise (used by scripts/deploy.sh)
# ---------------------------------------------------------------------------
# GitHub personal access token with read access to github.com/odoo/enterprise
# ODOO_ENTERPRISE_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxx
# ODOO_VERSION=19.0
# Path to enterprise addons on the host (default: ./addons/enterprise)
# Set to an absolute path when deploying via Coolify:
# ENTERPRISE_ADDONS_PATH=/opt/odoo-enterprise

# ---------------------------------------------------------------------------
# Backup
# ---------------------------------------------------------------------------
BACKUP_RETENTION_DAYS=30
